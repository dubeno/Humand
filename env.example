# Humand 系统环境配置示例
# 复制此文件为 .env 并填入实际值

# DeepSeek API 配置
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 或者使用其他兼容 OpenAI 格式的API
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Web 服务配置
WEB_HOST=0.0.0.0
WEB_PORT=8000

# 审批系统配置
APPROVAL_TIMEOUT=3600
APPROVERS=admin@company.com,manager@company.com

# 企业微信机器人 (可选)
WECHAT_WEBHOOK_URL=

# 飞书机器人 (可选)
FEISHU_WEBHOOK_URL=

# 钉钉机器人 (可选)
DINGTALK_WEBHOOK_URL=

# Humand SDK 配置 (如果使用云端服务)
HUMAND_API_KEY=
HUMAND_BASE_URL=https://api.humand.io



